# Copy to .env.secrets (gitignored) then run:
#   base44 secrets set --env-file .env.secrets
#
# NEVER prefix with VITE_ — that exposes secrets in the browser bundle.

# ── Nvidia Build (NIM) — primary AI provider ──
# Get keys at https://build.nvidia.com/settings/api-keys (nvapi- prefix)
NVIDIA_API_KEY=nvapi-your_key_here

# Optional: separate key for light-tier calls (hints, grading, Feynman).
# Note: Nvidia's 40 RPM limit is per model per ACCOUNT — a second key on the
# same account does not raise throughput; it only separates usage/rotation.
NVIDIA_API_KEY_LIGHT=

# Optional overrides (defaults shown)
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
AI_HEAVY_MODEL=deepseek-ai/deepseek-v4-pro
AI_LIGHT_MODEL=deepseek-ai/deepseek-v4-flash

# ── Deprecated (Google Gemma) — remove after Nvidia cutover is stable ──
# GEMINI_API_KEY=your_google_ai_studio_api_key_here
