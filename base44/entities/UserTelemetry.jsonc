{
  "name": "UserTelemetry",
  "type": "object",
  "properties": {
    "userEmail": {
      "type": "string",
      "description": "Email of the owning user"
    },
    "daily": {
      "type": "object"
    },
    "timeEngagedSec": {
      "type": "number"
    },
    "globalCorrect": {
      "type": "number"
    },
    "globalAnswered": {
      "type": "number"
    },
    "cardsFlipped": {
      "type": "number"
    },
    "journeyStats": {
      "type": "object",
      "description": "Per-journey stats keyed by journeyId"
    }
  },
  "required": [],
  "rls": {
    "create": {
      "data.userEmail": "{{user.email}}"
    },
    "read": {
      "data.userEmail": "{{user.email}}"
    },
    "update": {
      "data.userEmail": "{{user.email}}"
    },
    "delete": {
      "data.userEmail": "{{user.email}}"
    }
  }
}
