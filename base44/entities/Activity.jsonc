{
  "name": "Activity",
  "type": "object",
  "properties": {
    "activityId": {
      "type": "string",
      "description": "Client-side stable ID"
    },
    "moduleId": {
      "type": "string",
      "description": "Null for journey-scoped activities"
    },
    "journeyId": {
      "type": "string"
    },
    "userEmail": {
      "type": "string",
      "description": "Email of the owning user"
    },
    "scope": {
      "type": "string",
      "description": "module | journey"
    },
    "type": {
      "type": "string",
      "description": "learningGuide | practiceQuiz | flashcardSet | feynman | freeRecall | synthesis | interleavedReview | journeyChallenge"
    },
    "status": {
      "type": "string",
      "description": "notGenerated | generating | ready | failed"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "content": {
      "type": "object",
      "description": "Config only — never stored quiz questions"
    },
    "stats": {
      "type": "object",
      "description": "totalSessions, avgAccuracy, lastScore, lastCompletedAt, dueCount"
    },
    "itemCount": {
      "type": "number"
    },
    "lastSessionAt": {
      "type": "number"
    },
    "createdAt": {
      "type": "number"
    },
    "updatedAt": {
      "type": "number"
    }
  },
  "required": [
    "activityId",
    "journeyId",
    "type",
    "scope",
    "status"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}
