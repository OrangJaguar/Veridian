{
  "name": "UserPreferences",
  "type": "object",
  "properties": {
    "userEmail": {
      "type": "string",
      "description": "Email of the owning user"
    },
    "themeDark": {
      "type": "boolean"
    },
    "haptics": {
      "type": "boolean"
    },
    "audio": {
      "type": "boolean"
    },
    "strictMode": {
      "type": "boolean"
    },
    "displayName": {
      "type": "string"
    },
    "username": {
      "type": "string"
    },
    "hintsShown": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notificationPref": {
      "type": "string",
      "description": "daily | urgent | off"
    },
    "defaultPrivacy": {
      "type": "string",
      "description": "private | public"
    },
    "defaultShowSources": {
      "type": "boolean"
    }
  },
  "required": [],
  "rls": {
    "create": {
      "data.userEmail": "{{user.email}}"
    },
    "read": {
      "data.userEmail": "{{user.email}}"
    },
    "update": {
      "data.userEmail": "{{user.email}}"
    },
    "delete": {
      "data.userEmail": "{{user.email}}"
    }
  }
}
