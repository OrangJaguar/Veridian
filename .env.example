# Base44 app credentials (required for local dev)
# Your app ID from the Base44 dashboard
VITE_BASE44_APP_ID=your_app_id

# Base URL of your Base44-hosted app
VITE_BASE44_APP_BASE_URL=https://veridianstudy.base44.app

# GEMINI_API_KEY is server-side only — do NOT add it here.
# Copy .env.secrets.example to .env.secrets and run: base44 secrets set --env-file .env.secrets
